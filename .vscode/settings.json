{
  "python.defaultInterpreterPath": "${userHome}/.venvs/aidemo2026",
  "python.terminal.activateEnvironment": true,

  "python.analysis.typeCheckingMode": "basic",
  "python.analysis.diagnosticMode": "openFilesOnly",

  "notebook.diff.ignoreOutputs": true,
  "notebook.diff.ignoreMetadata": true,

  "files.exclude": {
    "**/__pycache__": true,
    "**/*.pyc": true
  },

  "search.exclude": {
    "outputs": true,
    "runs": true,
    "logs": true,
    "cache": true,
    "tmp": true,
    "scratch": true,
    "notes": true,
    "**/__pycache__": true
  },
  "cursorpyright.analysis.diagnosticMode": "openFilesOnly",
  "cursorpyright.analysis.typeCheckingMode": "basic",
  "claude.preferredLocation": "sidebar",

  "python-envs.pythonProjects": [
    {
      "path": ".",
      "envManager": "ms-python.python:venv",
      "packageManager": "ms-python.python:pip"
    }
  ]
}
