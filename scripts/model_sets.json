{
  "_doc": "10_quickgen.py 専用 model entry 集。01-07 (legacy single-shot 系) は読まず、引き続き diffusers_probe.json を使う。各 entry のスキーマ:\n  base_model_id      : Hugging Face Hub repo id (必須)\n  width, height      : 生成解像度 (省略時 1024)\n  num_inference_steps, guidance_scale : sampler 設定 (必須)\n  mps_dtype, cuda_dtype, cpu_dtype    : device 別 dtype (float16/float32/bfloat16)\n  enable_attention_slicing_on_mps     : optional\n  vae_fp32_override                    : optional (SDXL 系 MPS fp16 黒画像対策)\n  enable_model_cpu_offload             : optional (大型 model 用)\n  max_sequence_length                  : optional (FLUX 系)\n  true_cfg_scale                       : optional (Qwen-Image)\n  scheduler                            : optional {class, config_overrides}\n  loras                                : optional list[{repo, weight_name, scale, name?}]。複数指定時は set_adapters 経由で stack。\n  notes                                : 自由記述 (人間向けメモ、code は無視)。",
  "default_model": "sd15",
  "model_sets": {
    "sd15": {
      "base_model_id": "stable-diffusion-v1-5/stable-diffusion-v1-5",
      "width": 1024,
      "height": 1024,
