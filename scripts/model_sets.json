      "guidance_scale": 7.5,
      "mps_dtype": "float16",
      "cuda_dtype": "float16",
      "cpu_dtype": "float32",
      "enable_attention_slicing_on_mps": true,
      "vae_fp32_override": true,
      "notes": "SD1.5。1024 生成では fp16 VAE が NaN になりやすいので vae_fp32_override で回避。SD1.5 は 512 訓練のため 1024 では構図破綻あり (比較用に敢えて)。"
    },
